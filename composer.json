{
    "name": "achetibi/laravel-satim",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "description": "Laravel package for integrating SATIM online payments.",
    "keywords": [
        "laravel",
        "satim",
        "cib",
        "edahabia",
        "payment",
        "payment-gateway",
        "ecommerce",
        "e-commerce",
        "e-payment",
        "paiement",
        "carte-cib",
        "algeria",
        "dz",
        "laravel-satim"
    ],
    "homepage": "https://github.com/achetibi/laravel-satim",
    "license": "MIT",
    "authors": [
        {
            "name": "Abderrahim CHETIBI",
            "email": "chetibi.abderrahim@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "guzzlehttp/guzzle": "^7.8",
        "guzzlehttp/psr7": "^2.4",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/validation": "^11.0|^12.0|^13.0",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1|^2.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0|^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0|^4.0",
        "pestphp/pest-plugin-type-coverage": "^2.0|^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "LaravelSatim\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaravelSatim\\Tests\\": "tests"
        }
    },
    "scripts": {
        "lint": "pint --preset psr12",
        "test:lint": "pint --preset psr12 --test",
        "test:types": "phpstan analyse --memory-limit=512M",
        "test:inline": "pest --colors=always",
        "test:parallel": "pest --colors=always --parallel --processes=3",
        "test": [
            "@test:lint",
            "@test:types",
            "@test:parallel"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaravelSatim\\SatimServiceProvider"
            ],
            "aliases": {
                "Satim": "LaravelSatim\\Facades\\Satim"
            }
        }
    }
}
